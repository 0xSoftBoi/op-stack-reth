# ============================================
# OP Stack + Reth Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# L1 Configuration (Required)
# ============================================
# Ethereum L1 RPC endpoint (Mainnet or Sepolia)
L1_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# L1 Beacon node endpoint (required for blob data)
L1_BEACON_URL=https://sepolia-beacon.example.com

# Trust L1 RPC (set to true if using a trusted provider)
L1_TRUST_RPC=false

# ============================================
# L1 Contract Addresses (Required)
# ============================================
# L2OutputOracle contract address on L1
L2_OUTPUT_ORACLE_ADDRESS=0x...

# ============================================
# Sequencer Configuration
# ============================================
# Enable sequencer mode (true for sequencer, false for replica)
SEQUENCER_ENABLED=true

# Number of L1 confirmations before including in L2
SEQUENCER_L1_CONFS=4

# Sequencer HTTP URL (for replicas to forward txs)
SEQUENCER_HTTP_URL=http://op-node:8547

# P2P key for sequencer (optional, will be generated if not set)
SEQUENCER_P2P_KEY=

# ============================================
# Batcher Configuration (Required for Sequencer)
# ============================================
# Private key for the batcher (must be funded on L1)
# DO NOT commit this to version control!
BATCHER_PRIVATE_KEY=0x...

# Maximum number of L1 blocks to include in a channel
BATCHER_MAX_CHANNEL_DURATION=1

# Safety margin for sub-batches
BATCHER_SUB_SAFETY_MARGIN=6

# Poll interval for new L2 blocks
BATCHER_POLL_INTERVAL=1s

# Number of L1 confirmations before considering tx finalized
BATCHER_NUM_CONFIRMATIONS=10

# Data availability type: "blobs" (EIP-4844) or "calldata"
DATA_AVAILABILITY_TYPE=blobs

# ============================================
# Proposer Configuration (Required for Sequencer)
# ============================================
# Private key for the proposer (must be funded on L1)
# DO NOT commit this to version control!
PROPOSER_PRIVATE_KEY=0x...

# Poll interval for new state roots
PROPOSER_POLL_INTERVAL=12s

# Number of L1 confirmations
PROPOSER_NUM_CONFIRMATIONS=10

# ============================================
# Monitoring Configuration (Optional)
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ============================================
# Chain IDs & RPC kind
# ============================================
L1_CHAIN_ID=11155111
L2_CHAIN_ID=42069
# op-node L1 RPC kind: standard | alchemy | quicknode | erigon | basic
L1_RPC_KIND=standard
# op-node sync: execution-layer (snap via reth) | consensus-layer
OP_NODE_SYNCMODE=execution-layer

# ============================================
# Config generation (op-deployer) — see scripts/generate-config.sh
# ============================================
# Deployer key, funded on L1, used to deploy the L1 rollup contracts. NEVER commit.
DEPLOYER_PRIVATE_KEY=0x...
# L1 contract release op-deployer should deploy (matches the devnet pin)
L1_CONTRACTS_LOCATOR=tag://op-contracts/v4.0.0

# ============================================
# Pinned image versions (override to upgrade; defaults track op-contracts v4.0.0)
# Verify tags against the official releases before bumping:
#   op-reth:     https://github.com/paradigmxyz/reth/releases
#   op-node etc: https://github.com/ethereum-optimism/optimism/releases
# ============================================
# OP_RETH_IMAGE=ghcr.io/paradigmxyz/op-reth:v1.3.12
# OP_NODE_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-node:v1.13.3
# OP_BATCHER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-batcher:v1.13.3
# OP_PROPOSER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-proposer:v1.10.0
# OP_DEPLOYER_IMAGE=us-docker.pkg.dev/oplabs-tools-artifacts/images/op-deployer:v0.4.2
